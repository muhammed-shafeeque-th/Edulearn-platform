# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

#Custom
_k8s
**/*prod*

# Local .terraform directories (contains downloaded providers and modules)
.terraform/

# Hide local state files and backups (State should live in a remote backend like S3)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all variable files that might contain secrets
*.tfvars
!*.tfvars.example
*.tfvars.json

# Override files (local testing tweaks)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Exclude built helm packages
*.tgz

# Exclude local dependency charts fetched via 'helm dependency update'
# Note: Keep Chart.lock committed to lock dependency versions!
charts/

# Local configuration and development overrides
.helm/
helm-values-local.yaml
*local-values.yaml

# NEVER commit unencrypted native Kubernetes secrets
secret.yaml
*secret*.yaml
secrets/

# Kubeconfig files containing cluster access credentials
kubeconfig
*kubeconfig*
.kube/

# Local development cluster states (e.g., Minikube, Kind)
.minikube/
.kind/

# Environment variables containing sensitive API keys or AWS tokens
.env
.env.*
!.env.example # Keep the example template tracked

# AWS CLI specific directories
.aws/

# Terragrunt cache directories (if you use Terragrunt)
.terragrunt-cache/

# SOPS / Ansible Vault decrypted files (unencrypted backups)
*.decrypted.*
